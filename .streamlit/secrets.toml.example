# Copy this structure into Streamlit Cloud secrets.
# Do not commit real credentials in .streamlit/secrets.toml.

[gcp_service_account]
type = "service_account"
project_id = "your-google-cloud-project-id"
private_key_id = "your-private-key-id"
private_key = """
-----BEGIN PRIVATE KEY-----
replace-with-private-key
-----END PRIVATE KEY-----
"""
client_email = "ga-audit-sheets@your-google-cloud-project-id.iam.gserviceaccount.com"
client_id = "your-client-id"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/ga-audit-sheets%40your-google-cloud-project-id.iam.gserviceaccount.com"
universe_domain = "googleapis.com"

[sheets]
spreadsheet_id = "1e_fp0fAOeEAHaRtFJUv-rt-i0sqUOhszYOrOk7Cv5QU"
worksheet_name = "Audit Logs"
template_worksheet_name = "Audit Templates"
template_rules_worksheet_name = "Audit Template Rules"
bulk_jobs_worksheet_name = "Bulk Audit Jobs"
bulk_results_worksheet_name = "Bulk Audit Results"

[neon]
database_url = "postgresql://user:password@host/dbname?sslmode=require"

[github]
owner = "adminjnmgit"
repo = "GA-audit"
workflow = "bulk-audit.yml"
ref = "main"
token = "github_pat_or_fine_grained_token_with_actions_write"

# Optional staging/prod comparison auth.
# STAGE_AUDIT_TOKEN = ""
# STAGE_AUDIT_TOKEN_PARAM = "audit_token"
# STAGE_AUTH_COOKIE_NAME = ""
# STAGE_AUTH_COOKIE_VALUE = ""
# STAGE_AUTH_COOKIE_DOMAIN = ""
# STAGE_AUTH_COOKIES = '[{"name":"cookie_name","value":"cookie_value","domain":".example.com","path":"/","secure":true,"httpOnly":true}]'
